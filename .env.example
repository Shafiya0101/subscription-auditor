# Set these as Space secrets/variables (Settings -> Variables and secrets).
# Leave unset to run the fully deterministic pipeline (no LLM, still works).
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# optional pricing overrides for the /metrics cost estimate (USD per 1K tokens)
PRICE_PER_1K_INPUT=0.00015
PRICE_PER_1K_OUTPUT=0.00060
